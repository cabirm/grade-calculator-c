#include <stdio.h>

int main() {
    int dersSayisi;
    float not, toplam = 0, ortalama;

    printf("Kac ders notu gireceksiniz? ");
    scanf("%d", &dersSayisi);

    for(int i = 1; i <= dersSayisi; i++) {
        printf("%d. notu girin: ", i);
        scanf("%f", &not);
        toplam += not;
    }

    ortalama = toplam / dersSayisi;

    printf("\nNot Ortalamasi: %.2f\n", ortalama);

    if(ortalama >= 50)
        printf("Durum: Gecti\n");
    else
        printf("Durum: Kaldi\n");

    return 0;
}
